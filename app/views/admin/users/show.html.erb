<!-- app/views/admin/users/show.html.erb -->
<div class="admin-container">
  <h1>Expenses for <%= @user.email %></h1>

  <div class="summary-stats">
    <p><strong>Total Expenses:</strong> <%= @expenses.count %></p>
    <p><strong>Total Amount:</strong> <%= number_to_currency(@expenses.sum(:amount)) %></p>
  </div>

  <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Amount</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
      <% @expenses.each do |expense| %>
        <tr>
          <td><%= expense.name %></td>
          <td><%= number_to_currency(expense.amount) %></td>
          <td><%= expense.date.strftime("%b %d, %Y") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= link_to "← Back to All Users", expenses_path, class: "back-link" %>
</div>