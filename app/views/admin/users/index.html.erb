<h1>All Users</h1>

<table class="table">
  <thead>
    <tr>
      <th>Email</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.email %></td>
        <td><%= link_to "View Expenses", admin_user_path(user) %></td>
      </tr>
    <% end %>
  </tbody>
</table>